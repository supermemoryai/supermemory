{
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./src",
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"strict": false,
		"moduleResolution": "bundler",
		"module": "ESNext",
		"target": "ES2022",
		"lib": ["ES2022", "DOM"],
		"types": ["react"],
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"isolatedModules": true
	},
	"include": ["src/client/**/*", "src/react/**/*", "src/ai-sdk/**/*"],
	"exclude": ["node_modules", "dist", "src/component"]
}
