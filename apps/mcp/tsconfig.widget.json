{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"skipLibCheck": true,
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"types": ["vite/client"],
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"baseUrl": ".",
		"noEmit": true
	},
	"include": ["src/widget/**/*", "src/shared/**/*"],
	"exclude": ["node_modules", "dist"]
}
