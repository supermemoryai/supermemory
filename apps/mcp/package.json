{
  "name": "supermemory-mcp",
  "version": "4.0.0",
  "type": "module",
  "portless": { "name": "mcp.dev.supermemory", "script": "dev:app" },
  "scripts": {
    "build:ui": "vite build",
    "dev": "portless",
    "dev:app": "vite build && wrangler dev --port ${PORT:-8788}",
    "deploy": "vite build && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "check-types": "tsc --noEmit",
    "test": "vite build && vitest run src",
    "test:e2e": "vite build && vitest run",
    "check": "bun run check-types && bun run test"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-beta.5",
    "hono": "^4.11.1",
    "posthog-node": "^5.18.0",
    "supermemory": "^4.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@modelcontextprotocol/client": "2.0.0-beta.5",
    "@modelcontextprotocol/ext-apps": "1.7.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "d3-force-3d": "^3.0.5",
    "force-graph": "^1.49.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.4.0"
  }
}
